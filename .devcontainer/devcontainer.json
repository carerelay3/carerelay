// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/git-lfs:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/stu-bell/devcontainer-features/node:0": {},
		"ghcr.io/jlaundry/devcontainer-features/mssql-odbc-driver:1": {},
		"ghcr.io/warrenbuckley/codespace-features/sqlite:1": {},
		"ghcr.io/nullcoder/devcontainer-features/stripe-cli:1": {},
		"ghcr.io/itsmechlark/features/postgresql:1": {},
		"ghcr.io/robbert229/devcontainer-features/postgresql-client:1": {},
		"ghcr.io/nucleuscloud/devcontainer-features/sqlc:1": {},
		"ghcr.io/devcontainers-extra/features/mysql-homebrew:1": {},
		"ghcr.io/devcontainers-extra/features/vercel-cli:1": {},
		"ghcr.io/siri404/devcontainer-ai-features/vercel-cli:1": {},
		"ghcr.io/rails/devcontainer/features/mysql-client:1": {},
		"ghcr.io/rails/devcontainer/features/postgres-client:1": {},
		"ghcr.io/nlstn/devcontainer-features/psql:1": {},
		"ghcr.io/devcontainer-config/features/dot-config:4": {},
		"ghcr.io/postfinance/devcontainer-features/dotnet:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"Supabase.vscode-supabase-extension"
			]
		}
	}

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "yarn install",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
